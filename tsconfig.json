{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitReturns": true,
    "skipLibCheck": true,
    "lib": ["ES2020", "DOM"],
    "outDir": "dist-types"
  },
  "include": ["src/**/*", "tests/**/*", "vite.config.ts"]
}
